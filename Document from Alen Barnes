#  MODULE 4 – STATISTICAL COMPUTATION
# ═══════════════════════════════════════════════════════════════════════════════

def compute_statistics(df: pd.DataFrame) -> dict:
    latest = df.sort_values("date").groupby("country").last().reset_index()

    stats = {
        "global": {
            "total_confirmed":  int(latest["confirmed"].sum()),
            "total_deaths":     int(latest["deaths"].sum()),
            "total_recovered":  int(latest["recovered"].sum()),
            "total_active":     int(latest["active"].sum()),
            "global_cfr":       round(latest["deaths"].sum() / latest["confirmed"].sum() * 100, 3),
            "global_recovery":  round(latest["recovered"].sum() / latest["confirmed"].sum() * 100, 2),
            "countries_tracked":int(latest["country"].nunique()),
            "date_range":       f"{df['date'].min().date()}  →  {df['date'].max().date()}",
        }
    }

    # Per-country stats
    country_stats = {}
    for _, row in latest.iterrows():
        c = row["country"]
        c_df = df[df["country"]==c]
        daily = c_df["daily_cases"].values
        country_stats[c] = {
            "confirmed":      int(row["confirmed"]),
            "deaths":         int(row["deaths"]),
            "recovered":      int(row["recovered"]),
            "active":         int(row["active"]),
            "cfr":            round(row["cfr"], 3),
            "recovery_rate":  round(row["recovery_rate"], 2),
            "cases_per_1m":   round(row["cases_per_1m"], 1),
            "deaths_per_1m":  round(row["deaths_per_1m"], 1),
            "peak_daily":     int(np.max(daily)),
            "mean_daily":     round(float(np.mean(daily)), 1),
            "std_daily":      round(float(np.std(daily)), 1),
            "median_daily":   round(float(np.median(daily)), 1),
        }

    stats["countries"] = country_stats
    print("  ✓ Statistical computation complete")
    return stats


