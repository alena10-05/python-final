# --- Chart 2: Country Comparison Bar Chart ---
def chart_country_comparison(stats: dict) -> str:
    cs = stats["countries"]
    countries = list(cs.keys())
    confirmed = [cs[c]["confirmed"]/1e6 for c in countries]
    deaths    = [cs[c]["deaths"]/1e6    for c in countries]
    cfr       = [cs[c]["cfr"]           for c in countries]

    idx = np.argsort(confirmed)[::-1]
    countries = [countries[i] for i in idx]
    confirmed = [confirmed[i] for i in idx]
    deaths    = [deaths[i]    for i in idx]
    cfr       = [cfr[i]       for i in idx]

    fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(15, 6), facecolor=PALETTE["bg"])

    x = np.arange(len(countries))
    w = 0.4
    bars1 = ax1.bar(x - w/2, confirmed, w, color=PALETTE["accent1"], alpha=0.85, label="Confirmed")
    bars2 = ax1.bar(x + w/2, deaths,    w, color=PALETTE["accent2"], alpha=0.85, label="Deaths")
    ax1.set_xticks(x); ax1.set_xticklabels(countries, rotation=35, ha="right", fontsize=9)
    ax1.set_ylabel("Cases (Millions)"); ax1.set_title("Total Confirmed vs Deaths by Country", fontsize=12, color=PALETTE["text"])
    ax1.legend(facecolor=PALETTE["surface"], edgecolor=PALETTE["border"], labelcolor=PALETTE["text"])
    ax1.grid(axis="y", alpha=0.3); ax1.spines[['top','right']].set_visible(False)

    colors = [PALETTE["accent2"] if c > np.mean(cfr) else PALETTE["accent3"] for c in cfr]
    bars = ax2.barh(countries, cfr, color=colors, alpha=0.85)
    ax2.axvline(np.mean(cfr), color=PALETTE["accent4"], linestyle="--", lw=1.5, label=f"Mean CFR: {np.mean(cfr):.2f}%")
    for bar, val in zip(bars, cfr):
        ax2.text(val + 0.01, bar.get_y() + bar.get_height()/2, f"{val:.2f}%",
                 va="center", fontsize=8, color=PALETTE["text"])
    ax2.set_xlabel("Case Fatality Rate (%)"); ax2.set_title("Case Fatality Rate by Country", fontsize=12, color=PALETTE["text"])
    ax2.legend(facecolor=PALETTE["surface"], edgecolor=PALETTE["border"], labelcolor=PALETTE["text"])
    ax2.grid(axis="x", alpha=0.3); ax2.spines[['top','right']].set_visible(False)

    fig.tight_layout(pad=2)
    return fig_to_b64(fig)


# --- Chart 3: Heatmap (monthly cases) ---
def chart_heatmap(df: pd.DataFrame) -> str:
    df2 = df.copy()
    df2["month"] = df2["date"].dt.to_period("M")
    monthly = df2.groupby(["country","month"])["daily_cases"].sum().reset_index()
    pivot   = monthly.pivot(index="country", columns="month", values="daily_cases").fillna(0)
    pivot   = pivot / 1_000  # thousands

    # Sample every 3rd month for readability
    cols = pivot.columns[::3]
    pivot = pivot[cols]

    fig, ax = plt.subplots(figsize=(16, 6), facecolor=PALETTE["bg"])
    cmap = LinearSegmentedColormap.from_list("covid", ["#0D1117","#1a3a5c","#58A6FF","#F78166","#ff4d4d"])
    im = ax.imshow(pivot.values, aspect="auto", cmap=cmap, interpolation="nearest")
    ax.set_yticks(range(len(pivot.index))); ax.set_yticklabels(pivot.index, fontsize=10)
    ax.set_xticks(range(len(cols))); ax.set_xticklabels([str(c) for c in cols], rotation=45, ha="right", fontsize=8)
    ax.set_title("Monthly COVID-19 Cases Heatmap by Country (thousands)", fontsize=13, color=PALETTE["text"], pad=10)
    cbar = plt.colorbar(im, ax=ax, pad=0.01)
    cbar.set_label("Cases (K)", color=PALETTE["muted"])
    cbar.ax.yaxis.set_tick_params(color=PALETTE["muted"])
    plt.setp(cbar.ax.yaxis.get_ticklabels(), color=PALETTE["muted"])
    fig.tight_layout()
    return fig_to_b64(fig)


# --- Chart 4: Top countries rolling wave ---
def chart_waves(df: pd.DataFrame) -> str:
    top3 = ["USA","India","Brazil"]
    fig, axes = plt.subplots(3, 1, figsize=(14, 10), facecolor=PALETTE["bg"], sharex=True)
    fig.subplots_adjust(hspace=0.15)
    colors_list = [PALETTE["accent1"], PALETTE["accent4"], PALETTE["accent3"]]

    for ax, country, col in zip(axes, top3, colors_list):
        c_df = df[df["country"]==country].sort_values("date")
        ax.fill_between(c_df["date"], c_df["roll7_cases"].fillna(0)/1e3, alpha=0.25, color=col)
        ax.plot(c_df["date"], c_df["roll7_cases"].fillna(0)/1e3, color=col, lw=2)
        ax.set_ylabel(f"{country}\n(K cases)", color=PALETTE["muted"], fontsize=9)
        ax.grid(True, alpha=0.25); ax.spines[['top','right']].set_visible(False)
        peak = c_df["roll7_cases"].max()
        peak_date = c_df.loc[c_df["roll7_cases"].idxmax(), "date"]
        ax.annotate(f"Peak: {peak/1e3:.1f}K", xy=(peak_date, peak/1e3),
                    xytext=(30, -15), textcoords="offset points",
                    color=col, fontsize=8,
                    arrowprops=dict(arrowstyle="->", color=col, lw=1))

    axes[0].set_title("COVID-19 Wave Analysis — Top 3 Countries (7-day Rolling Avg)", fontsize=13, color=PALETTE["text"], pad=10)
    fig.tight_layout()
    return fig_to_b64(fig)


# --- Chart 5: Scatter — Cases per 1M vs Deaths per 1M ---
def chart_scatter(df: pd.DataFrame, stats: dict) -> str:
    cs = stats["countries"]
    countries = list(cs.keys())
    x   = np.array([cs[c]["cases_per_1m"]  for c in countries])
    y   = np.array([cs[c]["deaths_per_1m"] for c in countries])
    cfr = np.array([cs[c]["cfr"]           for c in countries])
    sizes = np.array([cs[c]["confirmed"] for c in countries]) / 1e5

    fig, ax = plt.subplots(figsize=(10, 7), facecolor=PALETTE["bg"])
    sc = ax.scatter(x, y, s=sizes, c=cfr, cmap="RdYlGn_r", alpha=0.85,
                    linewidths=1.2, edgecolors=PALETTE["border"])
    for i, country in enumerate(countries):
        ax.annotate(country, (x[i], y[i]), textcoords="offset points",
                    xytext=(6, 4), fontsize=8.5, color=PALETTE["text"])

    cbar = plt.colorbar(sc, ax=ax)
    cbar.set_label("CFR (%)", color=PALETTE["muted"])
    cbar.ax.yaxis.set_tick_params(color=PALETTE["muted"])
    plt.setp(cbar.ax.yaxis.get_ticklabels(), color=PALETTE["muted"])

    # Regression line
    m, b = np.polyfit(x, y, 1)
    x_line = np.linspace(x.min(), x.max(), 100)
    ax.plot(x_line, m*x_line + b, "--", color=PALETTE["accent4"], lw=1.5, label=f"Trend  r={np.corrcoef(x,y)[0,1]:.3f}")
    ax.set_xlabel("Confirmed Cases per Million", fontsize=10)
    ax.set_ylabel("Deaths per Million", fontsize=10)
    ax.set_title("Cases vs Deaths per Million Population\n(Bubble size ∝ total confirmed cases)", fontsize=12, color=PALETTE["text"])
    ax.legend(facecolor=PALETTE["surface"], edgecolor=PALETTE["border"], labelcolor=PALETTE["text"])
    ax.grid(True, alpha=0.25); ax.spines[['top','right']].set_visible(False)
    fig.tight_layout()
    return fig_to_b64(fig)


