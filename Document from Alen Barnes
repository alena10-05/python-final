def main():
    print("\n╔══════════════════════════════════════════════════════╗")
    print("║   COVID-19 DATA ANALYSIS APPLICATION   Micro-03     ║")
    print("╚══════════════════════════════════════════════════════╝\n")

    print("[1/6] Generating dataset …")
    df = generate_dataset()
    print(f"  ✓ Dataset shape: {df.shape}")

    print("[2/6] Initialising database …")
    conn = init_database(df)

    print("[3/6] Preprocessing …")
    df = preprocess(df)

    print("[4/6] Computing statistics …")
    stats = compute_statistics(df)
    g = stats["global"]
    print(f"  ✓ Global confirmed : {g['total_confirmed']:,}")
    print(f"  ✓ Global deaths    : {g['total_deaths']:,}")
    print(f"  ✓ CFR              : {g['global_cfr']}%")
    print(f"  ✓ Recovery rate    : {g['global_recovery']}%")

    print("[5/6] Running query-based retrieval …")
    q1 = query_db(conn, """
        SELECT country,
               MAX(confirmed) AS total_confirmed,
               MAX(deaths)    AS total_deaths,
               ROUND(MAX(deaths)*100.0/MAX(confirmed),3) AS cfr_pct
        FROM covid_data
        GROUP BY country
        ORDER BY total_confirmed DESC
    """)
    q2 = query_db(conn, """
        SELECT date, country, daily_cases, daily_deaths
        FROM covid_data
        WHERE daily_cases = (SELECT MAX(daily_cases) FROM covid_data WHERE country=covid_data.country)
        ORDER BY daily_cases DESC
        LIMIT 10
    """)
    q3 = query_db(conn, """
        SELECT strftime('%Y-%m', date) AS month,
               SUM(daily_cases)        AS total_new_cases,
               SUM(daily_deaths)       AS total_new_deaths
        FROM covid_data
        GROUP BY month
        ORDER BY month
        LIMIT 12
    """)
    query_results = {
        "Country Summary — Confirmed, Deaths, CFR": q1,
        "Peak Daily Cases per Country (Top 10)":    q2,
        "Global Monthly Aggregation (First Year)":  q3,
    }
    print("  ✓ 3 queries executed")

    print("[6/6] Generating visualisations & building dashboard …")
    charts = {
        "global_trend":       chart_global_trend(df),
        "country_comparison": chart_country_comparison(stats),
        "heatmap":            chart_heatmap(df),
        "waves":              chart_waves(df),
        "scatter":            chart_scatter(df, stats),
        "stats_distribution": chart_stats_distribution(df),
    }
    print("  ✓ 6 charts generated")

    html = build_dashboard(stats, charts, query_results)
    with open(HTML_OUT, "w", encoding="utf-8") as f:
        f.write(html)
    print(f"\n  ✓ Dashboard written → {HTML_OUT}")
    conn.close()
    print("\n✓ Pipeline complete.\n")


