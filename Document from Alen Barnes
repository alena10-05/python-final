def build_dashboard(stats: dict, charts: dict, query_results: dict) -> str:
    g  = stats["global"]
    cs = stats["countries"]

    def fmt(n):
        if n >= 1_000_000: return f"{n/1_000_000:.2f}M"
        if n >= 1_000:     return f"{n/1_000:.1f}K"
        return str(n)

    # Country table rows
    rows_html = ""
    for c, d in sorted(cs.items(), key=lambda x: x[1]["confirmed"], reverse=True):
        rows_html += f"""
        <tr>
          <td><span class="country-flag">{c}</span></td>
          <td class="num blue">{fmt(d['confirmed'])}</td>
          <td class="num red">{fmt(d['deaths'])}</td>
          <td class="num green">{fmt(d['recovered'])}</td>
          <td class="num amber">{fmt(d['active'])}</td>
          <td class="num">{d['cfr']}%</td>
          <td class="num">{d['recovery_rate']}%</td>
          <td class="num">{fmt(int(d['cases_per_1m']))}</td>
          <td class="num">{fmt(int(d['peak_daily']))}</td>
        </tr>"""

    # Query results section
    q_html = ""
    for title, qdf in query_results.items():
        q_html += f"<h3 class='q-title'>▸ {title}</h3>"
        q_html += "<div class='table-wrap'>" + qdf.to_html(index=False, classes="data-table", border=0) + "</div>"

