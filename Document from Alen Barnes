def init_database(df: pd.DataFrame) -> sqlite3.Connection:
    conn = sqlite3.connect(DB_PATH)
    c    = conn.cursor()
    c.execute("DROP TABLE IF EXISTS covid_data")
    c.execute("""
        CREATE TABLE covid_data (
            id           INTEGER PRIMARY KEY AUTOINCREMENT,
            date         TEXT,
            country      TEXT,
            confirmed    INTEGER,
            deaths       INTEGER,
            recovered    INTEGER,
            active       INTEGER,
            daily_cases  INTEGER,
            daily_deaths INTEGER,
            population   INTEGER
        )
    """)
    df_db = df.copy()
    df_db["date"] = df_db["date"].astype(str)
    df_db.to_sql("covid_data", conn, if_exists="replace", index=False)
    conn.commit()
    print(f"  ✓ Database initialised  →  {len(df)} records stored")
    return conn


def query_db(conn: sqlite3.Connection, sql: str) -> pd.DataFrame:
    return pd.read_sql_query(sql, conn)


