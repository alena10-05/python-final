#  MODULE 3 – PREPROCESSING
# ═══════════════════════════════════════════════════════════════════════════════

def preprocess(df: pd.DataFrame) -> pd.DataFrame:
    df = df.copy()
    # Clip negatives
    for col in ["confirmed","deaths","recovered","active","daily_cases","daily_deaths"]:
        df[col] = df[col].clip(lower=0)
    # Fill any NaN
    df.fillna(0, inplace=True)
    # Derived features
    df["cfr"]          = np.where(df["confirmed"]>0, df["deaths"]/df["confirmed"]*100, 0)
    df["cases_per_1m"] = df["confirmed"] / (df["population"] / 1_000_000)
    df["deaths_per_1m"]= df["deaths"]    / (df["population"] / 1_000_000)
    df["recovery_rate"]= np.where(df["confirmed"]>0, df["recovered"]/df["confirmed"]*100, 0)
    # 7-day rolling average per country
    df = df.sort_values(["country","date"])
    df["roll7_cases"]  = df.groupby("country")["daily_cases"].transform(lambda x: x.rolling(7).mean())
    df["roll7_deaths"] = df.groupby("country")["daily_deaths"].transform(lambda x: x.rolling(7).mean())
    print(f"  ✓ Preprocessing complete  →  {df.shape[1]} features, {df.shape[0]} rows")
    return df


