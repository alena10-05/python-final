    im = ax4.imshow(corr, cmap="coolwarm", vmin=-1, vmax=1, aspect="auto")
    ticks = range(len(countries))
    ax4.set_xticks(ticks); ax4.set_yticks(ticks)
    ax4.set_xticklabels(countries, rotation=45, ha="right", fontsize=8)
    ax4.set_yticklabels(countries, fontsize=8)
    for i in range(len(countries)):
        for j in range(len(countries)):
            ax4.text(j, i, f"{corr[i,j]:.2f}", ha="center", va="center",
                     fontsize=7, color="white" if abs(corr[i,j]) > 0.5 else PALETTE["text"])
    plt.colorbar(im, ax=ax4, label="Correlation")
    ax4.set_title("Cross-Country Daily Cases Correlation", fontsize=11, color=PALETTE["text"])

    fig.tight_layout(pad=2.5)
    return fig_to_b64(fig)


